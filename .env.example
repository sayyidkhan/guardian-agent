# Optional for persistent Redis storage (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional for LLM reasoning (fallback heuristic used when missing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Speechmatics STT (required for voice transcription)
SPEECHMATICS_API_KEY=
SPEECHMATICS_LANGUAGE=en
SPEECHMATICS_API_BASE_URL=https://asr.api.speechmatics.com/v2

# Vapi (voice agent)
# Safe to expose in browser bundle
VITE_VAPI_PUBLIC_KEY=6e9713b8-4a34-4000-811a-263f8644a7ae
# Assistant ID is selected dynamically in the UI (override field)
# Secret server-side key (never expose in frontend)
VAPI_API_KEY=

# Local API port
PORT=3000
