# Optional for persistent Redis storage (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional for LLM reasoning (fallback heuristic used when missing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Speechmatics STT (required for voice transcription)
SPEECHMATICS_API_KEY=
SPEECHMATICS_LANGUAGE=en
SPEECHMATICS_API_BASE_URL=https://asr.api.speechmatics.com/v2

# Vapi (voice agent)
# Get public key from dashboard.vapi.ai → Account → API Keys (must match the org of your assistant)
VITE_VAPI_PUBLIC_KEY=
# Secret server-side key (used for health check, never expose in frontend)
VAPI_API_KEY=

# Local API port
PORT=3000
