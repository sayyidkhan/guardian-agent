# Optional for persistent Redis storage (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional for LLM reasoning (fallback heuristic used when missing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Speechmatics STT (required for voice transcription)
SPEECHMATICS_API_KEY=
SPEECHMATICS_LANGUAGE=en
SPEECHMATICS_API_BASE_URL=https://asr.api.speechmatics.com/v2

# Local API port
PORT=3000
